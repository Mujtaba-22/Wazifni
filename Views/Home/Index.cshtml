@model HomeIndexViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Wazifni"];
}

<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <span class="badge bg-primary-subtle text-primary fw-bold rounded-pill px-3 py-2 mb-3">@Model.HeroBadge</span>
                <h1 class="display-5 fw-bolder mb-3">@Model.HeroTitle</h1>
                <p class="lead text-muted mb-4">@Model.HeroDescription</p>
                <div class="d-flex flex-wrap gap-2">
                </div>
            </div>
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 p-md-5">
                        <h2 class="h4 fw-bold mb-3">لماذا وظفني؟</h2>
                        <ul class="list-unstyled mb-0 d-grid gap-3">
                            @foreach (var feature in Model.Features)
                            {
                                <li class="d-flex gap-3"><i class="bi @feature.Icon text-primary fs-5"></i><span><strong>@feature.Title</strong> - @feature.Description</span></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
