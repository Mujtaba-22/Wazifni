@model DashboardViewModel

@{
    ViewData["Title"] = "لوحة التحكم";
}

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
            <div>
                <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 mb-2">إدارة المحتوى</span>
                <h1 class="h2 fw-bolder mb-1">لوحة التحكم</h1>
                <p class="text-muted mb-0">إنشاء وتعديل الأقسام والمهارات من مكان واحد.</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Department" asp-action="Create" class="btn btn-primary rounded-pill px-4">إضافة قسم</a>
                <a asp-controller="Skill" asp-action="Create" class="btn btn-outline-primary rounded-pill px-4">إضافة مهارة</a>
            </div>
        </div>

        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="alert alert-info rounded-4 border-0 shadow-sm mb-4">@statusMessage</div>
        }

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h2 class="h5 fw-bold mb-0">الأقسام</h2>
                            <span class="badge text-bg-light border">@Model.Departments.Count</span>
                        </div>

                        <div class="d-grid gap-3">
                            @foreach (var department in Model.Departments)
                            {
                                <div class="border rounded-4 p-3 d-flex align-items-center justify-content-between gap-3">
                                    <div>
                                        <div class="fw-bold">@department.Name</div>
                                        <small class="text-muted">@department.Description</small>
                                    </div>
                                    <div class="d-flex gap-2 flex-wrap justify-content-end">
                                        <a asp-controller="Department" asp-action="Edit" asp-route-id="@department.DeptId" class="btn btn-sm btn-outline-primary rounded-pill">تعديل</a>
                                        <form asp-controller="Department" asp-action="Delete" asp-route-id="@department.DeptId" method="post" onsubmit="return confirm('هل تريد حذف هذا القسم؟');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">حذف</button>
                                        </form>
                                    </div>
                                </div>
                            }

                            @if (!Model.Departments.Any())
                            {
                                <div class="text-muted">لا توجد أقسام بعد.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h2 class="h5 fw-bold mb-0">المهارات</h2>
                            <span class="badge text-bg-light border">@Model.Skills.Count</span>
                        </div>

                        <div class="d-grid gap-3">
                            @foreach (var skill in Model.Skills)
                            {
                                <div class="border rounded-4 p-3 d-flex align-items-center justify-content-between gap-3">
                                    <div class="fw-bold">@skill.Name</div>
                                    <div class="d-flex gap-2 flex-wrap justify-content-end">
                                        <a asp-controller="Skill" asp-action="Edit" asp-route-id="@skill.SkillId" class="btn btn-sm btn-outline-primary rounded-pill">تعديل</a>
                                        <form asp-controller="Skill" asp-action="Delete" asp-route-id="@skill.SkillId" method="post" onsubmit="return confirm('هل تريد حذف هذه المهارة؟');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">حذف</button>
                                        </form>
                                    </div>
                                </div>
                            }

                            @if (!Model.Skills.Any())
                            {
                                <div class="text-muted">لا توجد مهارات بعد.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>