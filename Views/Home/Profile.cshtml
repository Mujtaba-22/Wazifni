@model FreelancerProfileViewModel

@{
    ViewData["Title"] = "تفاصيل المستقل";
}

<section class="py-4">
    <div class="container ">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb bg-transparent p-0 mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">الرئيسية</a></li>
                <li class="breadcrumb-item"><a asp-controller="Department" asp-action="Index" class="text-decoration-none">@Model.DepartmentName</a></li>
                <li class="breadcrumb-item active">@Model.FullName</li>
            </ol>
        </nav>

        <div class="card border-0 shadow-sm overflow-hidden rounded-4">
            <div class="bg-primary bg-gradient text-white p-4 p-md-5">
                <div class="d-flex flex-column flex-md-row align-items-center gap-3">
                    <div class="bg-white bg-opacity-10 rounded-circle d-grid place-items-center d-flex justify-content-center" style="width:96px;height:96px;font-size:2.5rem;">
                        <i class="bi bi-person"></i>
                    </div>
                    <div class="flex-grow-1 text-center text-md-start">
                        <h1 class="h3 fw-bold mb-1">@Model.FullName</h1>
                        <p class="mb-0 text-white-50">@Model.Title</p>
                        <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-md-start mt-3">
                            <span class="badge bg-white text-primary rounded-pill px-3 py-2">@Model.DepartmentName</span>
                            <span class="badge bg-white text-primary rounded-pill px-3 py-2">@Model.Title</span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 flex-wrap justify-content-center">
                        <a href="mailto:@Model.Email" class="btn btn-light rounded-pill px-4"><i class="bi bi-envelope me-1"></i>إيميل</a>
                        <a href="@Model.WhatsAppUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-light rounded-pill px-4"><i class="bi bi-whatsapp me-1"></i>واتساب</a>
                    </div>
                </div>
            </div>

            <div class="card-body p-4 p-md-5">
                <div class="row g-4">
                    <div class="col-lg-8">
                        <h2 class="h5 fw-bold mb-3">النبذة التعريفية</h2>
                        <p class="text-muted lh-lg">@Model.Bio</p>

                        <h3 class="h6 fw-bold mt-4 mb-3">المهارات</h3>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var skill in Model.Skills)
                            {
                                <span class="badge text-bg-light border">@skill</span>
                            }
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="border rounded-4 p-4 bg-body-tertiary h-100">
                            <h2 class="h6 fw-bold mb-3">معلومات إضافية</h2>
                            <div class="d-grid gap-3">
                                <div class="d-flex gap-3 align-items-center ">
                                    <div class="d-flex justify-content-center bg-primary-subtle text-primary rounded-3 d-grid place-items-center" style="width:40px;height:40px;"><i class="bi bi-diagram-3"></i></div>
                                    <div><small class="text-muted d-block">القسم</small><span class="fw-semibold">@Model.DepartmentName</span></div>
                                </div>
                                <div class="d-flex gap-3 align-items-center">
                                    <div class="d-flex justify-content-center bg-primary-subtle text-primary rounded-3 d-grid place-items-center" style="width:40px;height:40px;"><i class="bi bi-stars"></i></div>
                                    <div><small class="text-muted d-block">المهارة</small><span class="fw-semibold">@Model.Title</span></div>
                                </div>
                                <div class="d-flex gap-3 align-items-center">
                                    <div class="d-flex justify-content-center bg-primary-subtle text-primary rounded-3 d-grid place-items-center" style="width:40px;height:40px;"><i class="bi bi-telephone"></i></div>
                                    <div><small class="text-muted d-block">الجوال</small><span class="fw-semibold">@Model.Phone</span></div>
                                </div>
                                <div class="d-flex gap-3 align-items-center">
                                    <div class="d-flex justify-content-center bg-primary-subtle text-primary rounded-3 d-grid place-items-center" style="width:40px;height:40px;"><i class="bi bi-geo-alt"></i></div>
                                    <div><small class="text-muted d-block">المدينة</small><span class="fw-semibold">@Model.City</span></div>
                                </div>
                                <div class="d-flex gap-3 align-items-center">
                                    <div class="d-flex justify-content-center bg-primary-subtle text-primary rounded-3 d-grid place-items-center" style="width:40px;height:40px;"><i class="bi bi-briefcase"></i></div>
                                    <div><small class="text-muted d-block">سنوات الخبرة</small><span class="fw-semibold">@Model.YearsExperience سنوات</span></div>
                                </div>
                                <div class="d-flex gap-3 align-items-center">
                                    <div class="d-flex justify-content-center bg-primary-subtle text-primary rounded-3 d-grid place-items-center" style="width:40px;height:40px;"><i class="bi bi-file-earmark-person"></i></div>
                                    <div><small class="text-muted d-block">السيرة الذاتية</small><a href="@Model.CvUrl" download class="text-decoration-none fw-semibold">تحميل CV</a></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>