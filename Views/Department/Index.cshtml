@model DepartmentIndexViewModel

@{
    ViewData["Title"] = "قسم البرمجة";
}

<section class="py-4">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb bg-transparent p-0 mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">الرئيسية</a></li>
                <li class="breadcrumb-item active">@Model.DepartmentName</li>
            </ol>
        </nav>

        <div class="bg-primary bg-gradient text-white rounded-4 p-4 p-md-5 mb-4 position-relative overflow-hidden">
            <div class="position-relative" style="z-index:1">
                <h1 class="h2 fw-bolder mb-2"><i class="bi bi-laptop me-2"></i>قسم @Model.DepartmentName</h1>
                <p class="mb-3 text-white-50">@Model.Description</p>
                <span class="badge bg-white text-primary fw-bold px-3 py-2 rounded-pill">@Model.FreelancerCount مستقل</span>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var department in Model.Departments)
                    {
                        <a asp-controller="Department" asp-action="Index" asp-route-id="@department.DeptId"
                           class="btn @(department.DeptId == Model.DepartmentId ? "btn-primary" : "btn-outline-primary") rounded-pill px-3">
                            @department.Name
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body d-flex flex-wrap gap-3 justify-content-between align-items-center">
                <span class="fw-semibold text-muted">تصفح المستقلين</span>
                <div class="d-flex flex-wrap gap-2">
                    <input type="text" class="form-control rounded-pill" placeholder="ابحث..." style="width:200px;">
                    <select class="form-select rounded-pill" style="width:180px;">
                        <option value="">كل المهارات</option>
                        @foreach (var skill in Model.FilterSkills)
                        {
                            <option value="@skill.SkillId">@skill.Name</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var freelancer in Model.Freelancers)
            {
                <div class="col-md-6 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 text-center">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="bg-primary-subtle text-primary rounded-circle mx-auto mb-3 d-grid place-items-center" style="width:80px;height:80px;font-size:2rem;">
                                <i class="bi bi-person"></i>
                            </div>
                            <h3 class="h5 fw-bold">@freelancer.FullName</h3>
                            <p class="text-primary small fw-semibold mb-2">@freelancer.RoleTitle</p>
                            <p class="text-muted small flex-grow-1">@freelancer.Summary</p>
                            <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
                                @foreach (var skill in freelancer.Skills)
                                {
                                    <span class="badge text-bg-light border">@skill</span>
                                }
                            </div>
                            <a href="@freelancer.ProfileUrl" class="btn btn-outline-primary rounded-pill w-100 mb-2">عرض الملف</a>
                            <a href="@freelancer.ProfileUrl" class="btn btn-primary rounded-pill w-100">تواصل</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>