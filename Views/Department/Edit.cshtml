@model Wazifni.Models.Department

@{
    ViewData["Title"] = "تعديل قسم";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 p-md-5">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <div>
                                <h1 class="h3 fw-bold mb-1">تعديل القسم</h1>
                                <p class="text-muted mb-0">حدّث بيانات القسم ثم احفظ التغييرات.</p>
                            </div>
                            <a asp-controller="Home" asp-action="Dashboard" class="btn btn-outline-primary rounded-pill">رجوع</a>
                        </div>

                        <form asp-action="Edit" method="post">
                            <input type="hidden" asp-for="DeptId" />
                            <div asp-validation-summary="All" class="text-danger mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="Name" class="form-label"></label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Icon" class="form-label">الأيقونة</label>
                                <input asp-for="Icon" class="form-control" />
                                <span asp-validation-for="Icon" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Description" class="form-label"></label>
                                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary rounded-pill px-4">حفظ التعديلات</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}